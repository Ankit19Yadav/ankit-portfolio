---
import "@fontsource/inter/latin-100.css";
import "@fontsource/inter/latin-200.css";
import "@fontsource/inter/latin-300.css";
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/jetbrains-mono/latin-400.css";
import "@fontsource/jetbrains-mono/latin-500.css";
import "../styles/global.css";
import AsciiBackground from "../components/AsciiBackground.astro";
import Cursor from "../components/Cursor.astro";
import SectionNav from "../components/SectionNav.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { getEntry } from "astro:content";

const profileEntry = await getEntry("profile", "profile");
const profile = profileEntry!.data;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name}`,
  description = profile.tagline,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "light" || t === "dark") {
            document.documentElement.dataset.theme = t;
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <AsciiBackground />
    <Cursor />
    <SectionNav />
    <ThemeToggle />
    <slot />
  </body>
</html>
